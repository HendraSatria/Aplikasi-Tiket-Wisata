<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Curved Background -->
    <item>
        <shape>
            <gradient
                android:angle="135"
                android:endColor="@color/nature_green_dark"
                android:startColor="@color/nature_green"
                android:type="linear" />
            <corners
                android:bottomLeftRadius="40dp"
                android:bottomRightRadius="40dp" />
        </shape>
    </item>

    <!-- Decorative Circle Left -->
    <item
        android:left="-60dp"
        android:top="-60dp"
        android:right="0dp"
        android:bottom="0dp">
        <shape android:shape="oval">
            <solid android:color="#1AFFFFFF" />
            <size android:width="150dp" android:height="150dp" />
        </shape>
    </item>

    <!-- Decorative Circle Right -->
    <item
        android:right="-80dp"
        android:top="-20dp">
        <shape android:shape="oval">
            <solid android:color="#0DFFFFFF" />
            <size android:width="180dp" android:height="180dp" />
        </shape>
    </item>
</layer-list>
