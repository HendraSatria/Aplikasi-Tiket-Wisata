<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@color/white">

    <ImageView
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:src="@drawable/logo_utama"
        android:layout_marginBottom="32dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Selamat Datang di EcoTrip"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="@color/nature_green_dark"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Silakan masuk untuk melanjutkan pemesanan"
        android:textSize="14sp"
        android:textColor="@color/gray_dark"
        android:layout_marginBottom="48dp"
        android:gravity="center"/>

    <Button
        android:id="@+id/btn_login_google"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Daftar / Masuk dengan Google"
        android:textAllCaps="false"
        android:backgroundTint="@color/nature_green"
        android:textColor="@color/white"
        android:padding="12dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="Dengan mendaftar, Anda menyetujui Syarat &amp; Ketentuan kami"
        android:textSize="11sp"
        android:gravity="center"
        android:textColor="@color/gray_dark"/>

</LinearLayout>
